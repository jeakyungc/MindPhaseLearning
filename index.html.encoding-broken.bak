        'src/lib/page/page-engine-init.ts -> src/lib/page/full-editor-runtime.ts'),
      F('lifecycle-extensions-functions', 'load',
        'page-mount', 'community.load',
        'community', 'CommunityController',
        'mounted route controllers',
        'CommunityController.load()',
        'community catalog and installed extension state load',
        'src/lib/page/page-route-lifecycle.svelte.ts -> src/lib/page/controllers/community-controller.svelte.ts'),
      F('workspace-editor-functions', 'trigger',
        'workspace-tree-load', 'workspacePanel.apply',
        'document-open', 'handleWorkspaceRowClick',
        'visible workspace tree row',
        'openWorkspaceFile(path)',
        'row or graph selection starts document open',
        'src/lib/page/controllers/workspace-panel-controller.svelte.ts -> src/lib/page/workspace-interaction-runtime.ts'),
      F('workspace-index-functions', 'call',
        'workspace-create-file', 'CreateWorkspaceFileParams',
        'reindex', 'reindexWorkspace / reindexChangedPaths',
        'new workspace entry path',
        'IndexingClient.reindex*()',
        'workspace mutation produces reindex input',
        'src-tauri/src/application/index_service.rs -> src/lib/page/page-route-runtime-wiring.ts'),
      F('editor-index-functions', 'call',
        'document-save', 'SaveDocumentParams',
        'reindex', 'reindexWorkspace / reindexChangedPaths',
        'saved document content and path',
        'reindexChangedPaths({ paths })',
        'document save refreshes search and graph index sources',
        'src-tauri/src/application/index_service.rs -> src/lib/page/page-route-runtime-wiring.ts'),
