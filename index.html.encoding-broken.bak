        'unmount disposes graph worker/runtime resources',
        'src/lib/graph/core/GraphRuntime.ts -> src/lib/page/page-mounted-lifecycle-runtime.ts'),
      F('editor-cleanup-functions', 'cleanup',
        'editor-session', 'persistEditorSessionState',
        'page-unmount', 'pageRenderRuntime(); editorMotionScheduler()',
