          S('page', 'Render / motion з—Қв‘Ҙлғј', 'renderRuntime.dispose + scheduler.dispose', '?лҚүл№ҹ??RAF?ВҖ editor motion taskз‘ң?з—Қв‘Ҙлғј?в‘ёл•І??', 'pageRenderRuntime(); editorMotionScheduler()', 'src/lib/page/page-lifecycle.ts', 'Animation task йҶ«лӮ…мҰә'),
