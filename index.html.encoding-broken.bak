п»ҝ<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="color-scheme" content="dark" />
  <title>MindPhase Business Logic Lifecycle Visualizer</title>
  <style>
    :root {
      --bg: #080b12;
      --panel: rgba(16, 21, 33, 0.9);
      --panel-2: rgba(21, 28, 44, 0.84);
      --panel-3: rgba(30, 39, 58, 0.72);
      --border: rgba(151, 166, 207, 0.18);
      --border-strong: rgba(151, 166, 207, 0.34);
      --text: #f2f5ff;
      --muted: #9fa9bf;
      --muted-2: #747f98;
      --accent: #7f8cff;
      --accent-2: #4bd6c8;
      --accent-3: #ffbf69;
      --danger: #ff7f91;
      --success: #7ee2a8;
      --shadow: 0 18px 60px rgba(0, 0, 0, 0.34);
      --radius-lg: 24px;
      --radius-md: 16px;
      --radius-sm: 11px;
      --speed: 1.35s;
      --sidebar-width: 360px;
    }

    * { box-sizing: border-box; }

    html, body {
      min-height: 100%;
      margin: 0;
      background:
        radial-gradient(circle at 12% 8%, rgba(85, 100, 255, 0.18), transparent 26rem),
        radial-gradient(circle at 88% 4%, rgba(63, 207, 192, 0.11), transparent 30rem),
        linear-gradient(160deg, #090c14 0%, #070910 48%, #090d17 100%);
      color: var(--text);
      font-family: Inter, Pretendard, "Noto Sans KR", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    body { overflow-x: hidden; }

    button, input, select { font: inherit; }

    button {
      color: inherit;
      border: 0;
      cursor: pointer;
    }

    button:focus-visible,
    input:focus-visible,
    select:focus-visible,
    .flow-item:focus-visible {
      outline: 2px solid #a8b1ff;
      outline-offset: 2px;
    }

    .app-shell {
      display: grid;
      grid-template-columns: var(--sidebar-width) minmax(0, 1fr);
      min-height: 100vh;
    }

    .sidebar {
      position: sticky;
      top: 0;
      height: 100vh;
      display: flex;
      flex-direction: column;
      border-right: 1px solid var(--border);
      background: rgba(7, 10, 17, 0.84);
      backdrop-filter: blur(24px);
      z-index: 20;
    }

    .brand {
      padding: 24px 22px 18px;
      border-bottom: 1px solid var(--border);
    }

    .brand-row {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .brand-mark {
      width: 42px;
      aspect-ratio: 1;
      display: grid;
      place-items: center;
      border-radius: 13px;
      background:
        linear-gradient(145deg, rgba(127, 140, 255, 0.9), rgba(75, 214, 200, 0.62));
      box-shadow: 0 10px 32px rgba(92, 111, 255, 0.28);
      font-weight: 900;
      letter-spacing: -0.05em;
    }

    .brand h1 {
      margin: 0;
      font-size: 17px;
      letter-spacing: -0.02em;
    }

    .brand p {
      margin: 5px 0 0;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.5;
    }

    .search-wrap { padding: 14px 16px 8px; }

    .search-wrap input {
      width: 100%;
      height: 40px;
      padding: 0 13px;
      border: 1px solid var(--border);
      border-radius: 12px;
      color: var(--text);
      background: rgba(255, 255, 255, 0.045);
    }

    .search-wrap input::placeholder { color: var(--muted-2); }

    .flow-list {
      overflow: auto;
      padding: 6px 10px 20px;
      scrollbar-width: thin;
      scrollbar-color: rgba(160, 172, 205, 0.28) transparent;
    }

    .group-block { margin: 10px 0 16px; }

    .group-title {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 8px 7px;
      color: var(--muted-2);
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 0.11em;
      text-transform: uppercase;
    }

    .group-count {
      min-width: 22px;
      padding: 2px 6px;
      border-radius: 999px;
      text-align: center;
      color: var(--muted);
      background: rgba(255, 255, 255, 0.05);
    }

    .flow-item {
      width: 100%;
      display: grid;
      grid-template-columns: 30px minmax(0, 1fr) auto;
      align-items: center;
      gap: 9px;
      padding: 10px 10px;
      border-radius: 12px;
      text-align: left;
      background: transparent;
      transition: background 160ms ease, transform 160ms ease, color 160ms ease;
    }

    .flow-item:hover { background: rgba(255, 255, 255, 0.052); }

    .flow-item.active {
      background: linear-gradient(90deg, rgba(127, 140, 255, 0.2), rgba(75, 214, 200, 0.07));
      box-shadow: inset 0 0 0 1px rgba(139, 150, 255, 0.25);
    }

    .flow-index {
      width: 28px;
      height: 28px;
      display: grid;
      place-items: center;
      border-radius: 9px;
      color: var(--muted);
      background: rgba(255, 255, 255, 0.055);
      font-size: 11px;
      font-weight: 800;
    }

    .flow-item.active .flow-index {
      color: white;
      background: linear-gradient(145deg, #7684ff, #4cbfc0);
    }

    .flow-name {
      overflow: hidden;
      color: #d8def0;
      font-size: 12px;
      font-weight: 680;
      line-height: 1.35;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .flow-step-count {
      color: var(--muted-2);
      font-size: 10px;
      font-variant-numeric: tabular-nums;
    }


    .relation-toolbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      margin-top: 10px;
      padding: 9px 10px;
      border: 1px solid var(--border);
      border-radius: 11px;
      background: rgba(255, 255, 255, 0.032);
    }

    .relation-toolbar div {
      min-width: 0;
      display: grid;
      gap: 2px;
    }

    .relation-toolbar strong {
      color: #dfe5f7;
      font-size: 10px;
      letter-spacing: 0.02em;
    }

    .relation-toolbar span {
      overflow: hidden;
      color: var(--muted-2);
      font-size: 9px;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .relation-toggle {
      min-width: 38px;
      height: 25px;
      border: 1px solid var(--border);
      border-radius: 999px;
      color: var(--muted);
      background: rgba(255, 255, 255, 0.045);
      font-size: 9px;
      font-weight: 900;
      letter-spacing: 0.07em;
    }

    .relation-toggle.active {
      color: #f4f7ff;
      border-color: rgba(75, 214, 200, 0.42);
      background: rgba(75, 214, 200, 0.16);
    }

    .relation-legend {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 5px;
      margin-top: 7px;
      color: var(--muted-2);
      font-size: 8px;
    }

    .relation-legend span {
      display: flex;
      align-items: center;
      gap: 4px;
      min-width: 0;
      white-space: nowrap;
    }

    .relation-swatch {
      width: 6px;
      height: 6px;
      flex: 0 0 auto;
      border-radius: 50%;
      background: #7f8cff;
      box-shadow: 0 0 9px currentColor;
    }

    .relation-swatch.event { background: #4bd6c8; }
    .relation-swatch.sync { background: #38bdf8; }
    .relation-swatch.cleanup { background: #94a3b8; }

    .group-title {
      position: relative;
      min-height: 25px;
    }

    .group-title-main {
      min-width: 0;
      display: flex;
      align-items: center;
      gap: 7px;
    }

    .group-block.active-group .group-title { color: #dbe1f6; }

    .flow-meta {
      display: flex;
      align-items: center;
      gap: 5px;
    }

    .flow-relation-count {
      min-width: 22px;
      padding: 2px 5px;
      border-radius: 999px;
      color: #8dded6;
      background: rgba(75, 214, 200, 0.075);
      font-size: 8px;
      font-weight: 800;
      text-align: center;
    }

    .flow-relation-count:empty { display: none; }

    .flow-relation-map[hidden] { display: none; }

    .flow-relation-map {
      padding: 15px 18px 17px;
      border-bottom: 1px solid var(--border);
      background:
        linear-gradient(90deg, rgba(127, 140, 255, 0.06), rgba(75, 214, 200, 0.026)),
        rgba(255, 255, 255, 0.014);
    }

    .flow-relation-layout {
      display: grid;
      grid-template-columns: minmax(220px, 1fr) minmax(230px, 0.9fr) minmax(220px, 1fr);
      gap: 14px;
      align-items: stretch;
    }

    .flow-relation-column,
    .flow-current-card {
      min-width: 0;
      border: 1px solid rgba(151, 166, 207, 0.14);
      border-radius: 8px;
      background: rgba(8, 12, 20, 0.32);
    }

    .flow-relation-column {
      padding: 11px;
    }

    .flow-relation-column-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      margin-bottom: 9px;
    }

    .flow-relation-column-head strong {
      min-width: 0;
      color: #dce3f5;
      font-size: 11px;
      line-height: 1.35;
    }

    .flow-relation-badge {
      min-width: 24px;
      padding: 3px 7px;
      border-radius: 999px;
      color: #9ee5dc;
      background: rgba(75, 214, 200, 0.08);
      font-size: 9px;
      font-weight: 850;
      text-align: center;
      font-variant-numeric: tabular-nums;
    }

    .flow-link-stack {
      display: grid;
      gap: 8px;
    }

    .flow-link-empty {
      min-height: 72px;
      display: grid;
      place-items: center;
      padding: 12px;
      border: 1px dashed rgba(151, 166, 207, 0.16);
      border-radius: 8px;
      color: var(--muted-2);
      font-size: 10px;
      line-height: 1.5;
      text-align: center;
    }

    .flow-link-card {
      --relation-color: #7f8cff;
      width: 100%;
      display: flex;
      flex-direction: column;
      gap: 6px;
      min-height: 126px;
      padding: 10px;
      border: 1px solid color-mix(in srgb, var(--relation-color) 24%, transparent);
      border-radius: 8px;
      text-align: left;
      background: color-mix(in srgb, var(--relation-color) 7%, rgba(10, 14, 23, 0.8));
      transition: transform 150ms ease, border-color 150ms ease, background 150ms ease;
    }

    .flow-link-card:hover {
      transform: translateY(-1px);
      border-color: color-mix(in srgb, var(--relation-color) 52%, transparent);
      background: color-mix(in srgb, var(--relation-color) 12%, rgba(10, 14, 23, 0.86));
    }

    .flow-link-role {
      color: var(--relation-color);
      font-size: 9px;
      font-weight: 850;
    }

    .flow-link-title {
      color: #eef2ff;
      font-size: 12px;
      font-weight: 800;
      line-height: 1.35;
      overflow-wrap: anywhere;
    }

    .flow-link-route {
      color: #c5cede;
      font-size: 10px;
      line-height: 1.45;
      overflow-wrap: anywhere;
    }

    .flow-link-meta {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 5px;
      color: var(--muted);
      font-size: 10px;
    }

    .flow-link-kind {
      padding: 2px 6px;
      border-radius: 999px;
      color: var(--relation-color);
      background: color-mix(in srgb, var(--relation-color) 12%, transparent);
      font-size: 9px;
      font-weight: 850;
    }

    .flow-link-via {
      display: block;
      color: #b8c4e0;
      font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
      font-size: 9px;
      line-height: 1.45;
      overflow-wrap: anywhere;
    }

    .flow-link-copy {
      color: #aab4ca;
      font-size: 10px;
      line-height: 1.45;
      overflow-wrap: anywhere;
    }

    .function-edge-section {
      margin-top: 11px;
      padding-top: 10px;
      border-top: 1px solid rgba(151, 166, 207, 0.1);
    }

    .function-edge-title {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      margin-bottom: 8px;
      color: #dce3f5;
      font-size: 10px;
      font-weight: 850;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .function-edge-list {
      display: grid;
      gap: 7px;
    }

    .function-edge-card {
      width: 100%;
      display: grid;
      gap: 5px;
      padding: 9px;
      border: 1px solid rgba(75, 214, 200, 0.18);
      border-radius: 8px;
      background: rgba(75, 214, 200, 0.055);
      text-align: left;
    }

    .function-edge-route {
      color: #eef2ff;
      font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
      font-size: 9px;
      line-height: 1.45;
      overflow-wrap: anywhere;
    }

    .function-edge-meta,
    .function-edge-source {
      color: var(--muted);
      font-size: 9px;
      line-height: 1.45;
      overflow-wrap: anywhere;
    }

    .function-edge-source { color: #8ea0c6; }

    .flow-current-card {
      position: relative;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 11px;
      padding: 16px;
      border-color: rgba(127, 140, 255, 0.36);
      background:
        linear-gradient(145deg, rgba(127, 140, 255, 0.16), rgba(75, 214, 200, 0.07)),
        rgba(11, 15, 25, 0.74);
      box-shadow: inset 0 0 0 1px rgba(127, 140, 255, 0.08);
    }

    .flow-current-label {
      color: var(--accent-2);
      font-size: 10px;
      font-weight: 850;
    }

    .flow-current-title {
      color: #f2f5ff;
      font-size: 15px;
      font-weight: 850;
      line-height: 1.35;
      overflow-wrap: anywhere;
    }

    .flow-current-group {
      color: var(--muted);
      font-size: 11px;
    }

    .flow-current-stats {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .flow-current-stats span {
      padding: 5px 8px;
      border-radius: 999px;
      color: #cfd6ff;
      background: rgba(255, 255, 255, 0.055);
      font-size: 10px;
      font-variant-numeric: tabular-nums;
    }

    .main {
      min-width: 0;
      padding: 22px;
    }

    .topbar {
      position: sticky;
      top: 0;
      z-index: 15;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
      margin-bottom: 18px;
      padding: 12px 14px;
      border: 1px solid var(--border);
      border-radius: 17px;
      background: rgba(11, 15, 25, 0.78);
      backdrop-filter: blur(22px);
      box-shadow: var(--shadow);
    }

    .breadcrumb {
      min-width: 0;
      display: flex;
      align-items: center;
      gap: 8px;
      color: var(--muted);
      font-size: 12px;
    }

    .breadcrumb strong {
      overflow: hidden;
      color: var(--text);
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .controls {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .control-button,
    .select-control,
    .toggle-control {
      min-height: 36px;
      border: 1px solid var(--border);
      border-radius: 11px;
      background: rgba(255, 255, 255, 0.05);
      transition: background 150ms ease, border-color 150ms ease, transform 150ms ease;
    }

    .control-button {
      min-width: 38px;
      padding: 0 11px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 7px;
      font-size: 12px;
      font-weight: 750;
    }

    .control-button:hover,
    .toggle-control:hover { background: rgba(255, 255, 255, 0.09); }

    .control-button.primary {
      border-color: rgba(135, 147, 255, 0.5);
      background: linear-gradient(145deg, rgba(116, 130, 255, 0.88), rgba(70, 178, 181, 0.72));
      box-shadow: 0 8px 24px rgba(92, 111, 255, 0.18);
    }

    .select-control {
      height: 36px;
      padding: 0 28px 0 10px;
      color: var(--text);
      appearance: none;
      background-image:
        linear-gradient(45deg, transparent 50%, var(--muted) 50%),
        linear-gradient(135deg, var(--muted) 50%, transparent 50%);
      background-position:
        calc(100% - 13px) 15px,
        calc(100% - 9px) 15px;
      background-size: 4px 4px, 4px 4px;
      background-repeat: no-repeat;
    }

    .select-control option { color: #111827; }

    .toggle-control {
      height: 36px;
      padding: 0 10px;
      display: inline-flex;
      align-items: center;
      gap: 7px;
      font-size: 11px;
      color: var(--muted);
    }

    .toggle-control input { accent-color: var(--accent); }

    .hero {
      display: grid;
      grid-template-columns: minmax(0, 1.45fr) minmax(300px, 0.55fr);
      gap: 18px;
      margin-bottom: 18px;
    }

    .hero-card,
    .status-card,
    .flow-board,
    .detail-panel,
    .log-panel {
      border: 1px solid var(--border);
      background: var(--panel);
      box-shadow: var(--shadow);
    }

    .hero-card {
      position: relative;
      overflow: hidden;
      min-height: 224px;
      padding: 26px;
      border-radius: var(--radius-lg);
    }

    .hero-card::before {
      content: "";
      position: absolute;
      inset: auto -10% -55% 30%;
      height: 270px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(88, 105, 255, 0.26), transparent 68%);
      pointer-events: none;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 14px;
      color: #b9c1d8;
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .eyebrow::before {
      content: "";
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--accent-2);
      box-shadow: 0 0 16px rgba(75, 214, 200, 0.75);
    }

    .hero h2 {
      max-width: 760px;
      margin: 0;
      font-size: clamp(25px, 3.2vw, 45px);
      line-height: 1.08;
      letter-spacing: -0.045em;
    }

    .hero-summary {
      max-width: 790px;
      margin: 16px 0 0;
      color: #b3bdd2;
      font-size: 14px;
      line-height: 1.8;
    }

    .hero-meta {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
      margin-top: 22px;
    }

    .meta-chip {
      padding: 7px 10px;
      border: 1px solid rgba(151, 166, 207, 0.15);
      border-radius: 999px;
      color: #c6cfe4;
      background: rgba(255, 255, 255, 0.045);
      font-size: 11px;
    }

    .status-card {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 20px;
      border-radius: var(--radius-lg);
    }

    .status-label {
      color: var(--muted-2);
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .current-step-title {
      margin: 12px 0 8px;
      font-size: 19px;
      line-height: 1.35;
      letter-spacing: -0.025em;
    }

    .current-step-desc {
      color: var(--muted);
      font-size: 12px;
      line-height: 1.65;
    }

    .progress-shell { margin-top: 18px; }

    .progress-meta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 7px;
      color: var(--muted);
      font-size: 10px;
      font-variant-numeric: tabular-nums;
    }

    .progress-track {
      height: 7px;
      overflow: hidden;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.06);
    }

    .progress-bar {
      width: 0;
      height: 100%;
      border-radius: inherit;
      background: linear-gradient(90deg, var(--accent), var(--accent-2));
      box-shadow: 0 0 22px rgba(105, 130, 255, 0.45);
      transition: width 360ms cubic-bezier(.2, .8, .2, 1);
    }

    .content-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 340px;
      gap: 18px;
      align-items: start;
    }

    .flow-board {
      min-width: 0;
      overflow: hidden;
      border-radius: var(--radius-lg);
    }

    .board-head,
    .panel-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 16px 18px;
      border-bottom: 1px solid var(--border);
    }

    .board-head h3,
    .panel-head h3 {
      margin: 0;
      font-size: 13px;
      letter-spacing: -0.015em;
    }

    .board-head p,
    .panel-head p {
      margin: 4px 0 0;
      color: var(--muted-2);
      font-size: 10px;
    }

    .legend {
      display: flex;
      align-items: center;
      gap: 10px;
      color: var(--muted-2);
      font-size: 9px;
    }

    .legend-item {
      display: flex;
      align-items: center;
      gap: 5px;
    }

    .legend-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
    }

    .legend-dot.done { background: var(--success); }
    .legend-dot.active { background: var(--accent); box-shadow: 0 0 10px var(--accent); }
    .legend-dot.pending { background: #555e74; }

    .board-scroll {
      overflow: auto;
      padding: 0 0 12px;
      scrollbar-width: thin;
      scrollbar-color: rgba(160, 172, 205, 0.28) transparent;
    }

    .lane-heads {
      min-width: 980px;
      display: grid;
      grid-template-columns: repeat(6, minmax(146px, 1fr));
      border-bottom: 1px solid var(--border);
      background:
        linear-gradient(180deg, rgba(24, 32, 51, 0.94), rgba(14, 19, 31, 0.92));
      box-shadow: inset 0 -1px 0 rgba(255, 255, 255, 0.035);
    }

    .lane-head {
      --lane-color: var(--accent);
      position: relative;
      padding: 13px 10px;
      border-right: 1px solid rgba(151, 166, 207, 0.18);
      background:
        linear-gradient(180deg, color-mix(in srgb, var(--lane-color) 16%, transparent), transparent 74%),
        radial-gradient(circle at 50% 0, color-mix(in srgb, var(--lane-color) 18%, transparent), transparent 62%);
      text-align: center;
    }

    .lane-head:nth-child(1) { --lane-color: #7f8cff; }
    .lane-head:nth-child(2) { --lane-color: #69b7ff; }
    .lane-head:nth-child(3) { --lane-color: #4bd6c8; }
    .lane-head:nth-child(4) { --lane-color: #7ee2a8; }
    .lane-head:nth-child(5) { --lane-color: #ffbf69; }
    .lane-head:nth-child(6) { --lane-color: #ff8db3; }

    .lane-head:last-child { border-right: 0; }

    .lane-head::before {
      content: "";
      position: absolute;
      top: 0;
      left: 10px;
      right: 10px;
      height: 3px;
      border-radius: 999px;
      background: linear-gradient(90deg, transparent, var(--lane-color), transparent);
      box-shadow: 0 0 16px color-mix(in srgb, var(--lane-color) 48%, transparent);
    }

    .lane-head strong {
      display: block;
      color: #f7f9ff;
      font-size: 11px;
      letter-spacing: 0.02em;
      text-shadow: 0 0 16px color-mix(in srgb, var(--lane-color) 30%, transparent);
    }

    .lane-head span {
      display: block;
      margin-top: 3px;
      color: #9faac2;
      font-size: 8px;
    }

    .diagram-wrap {
      position: relative;
      min-width: 980px;
      min-height: 480px;
      padding: 16px 12px 28px;
      background:
        linear-gradient(
          to right,
          rgba(127, 140, 255, 0.078) 0,
          rgba(127, 140, 255, 0.078) 16.666%,
          rgba(105, 183, 255, 0.058) 16.666%,
          rgba(105, 183, 255, 0.058) 33.333%,
          rgba(75, 214, 200, 0.056) 33.333%,
          rgba(75, 214, 200, 0.056) 50%,
          rgba(126, 226, 168, 0.052) 50%,
          rgba(126, 226, 168, 0.052) 66.666%,
          rgba(255, 191, 105, 0.05) 66.666%,
          rgba(255, 191, 105, 0.05) 83.333%,
          rgba(255, 141, 179, 0.052) 83.333%,
          rgba(255, 141, 179, 0.052) 100%
        ),
        repeating-linear-gradient(
          to right,
          transparent 0,
          transparent calc(16.666% - 1px),
          rgba(151, 166, 207, 0.14) calc(16.666% - 1px),
          rgba(151, 166, 207, 0.14) 16.666%
        );
    }

    .diagram-grid {
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: repeat(6, minmax(146px, 1fr));
      grid-auto-rows: minmax(94px, auto);
      gap: 12px 12px;
    }

    .edge-layer {
      position: absolute;
      inset: 0;
      z-index: 6;
      width: 100%;
      height: 100%;
      overflow: visible;
      pointer-events: none;
    }

    .edge {
      fill: none;
      stroke: rgba(126, 226, 168, 0.42);
      stroke-width: 2.4;
      stroke-linecap: round;
      stroke-linejoin: round;
      transition: stroke 240ms ease, opacity 240ms ease, filter 240ms ease;
    }

    .edge.done { stroke: rgba(126, 226, 168, 0.58); }

    .edge.active {
      stroke: url(#activeGradient);
      stroke-width: 4;
      filter:
        drop-shadow(0 0 6px rgba(111, 128, 255, 0.72))
        drop-shadow(0 0 12px rgba(91, 213, 255, 0.36));
    }

    .edge.cross-edge {
      stroke: rgba(127, 140, 255, 0.56);
      stroke-dasharray: 8 6;
    }

    .edge.cross-edge.incoming {
      stroke: rgba(105, 183, 255, 0.64);
    }

    .edge.cross-edge.outgoing {
      stroke: rgba(255, 191, 105, 0.66);
    }

    .step-node {
      position: relative;
      align-self: center;
      min-width: 0;
      min-height: 74px;
      padding: 12px 12px 11px;
      border: 1px solid var(--border);
      border-radius: 14px;
      background: rgba(22, 29, 45, 0.84);
      box-shadow: 0 10px 28px rgba(0, 0, 0, 0.2);
      transition:
        transform 260ms cubic-bezier(.2, .8, .2, 1),
        border-color 260ms ease,
        background 260ms ease,
        opacity 260ms ease,
        filter 260ms ease;
    }

    .step-node.context-node {
      min-height: 68px;
      border-style: dashed;
      background: rgba(16, 22, 36, 0.78);
    }

    .step-node.incoming-node {
      border-color: rgba(105, 183, 255, 0.36);
    }

    .step-node.outgoing-node {
      border-color: rgba(255, 191, 105, 0.4);
    }

    .step-node.current-node {
      border-color: rgba(151, 166, 207, 0.24);
    }

    .step-node.symbol-node {
      border-radius: 10px;
      border-color: rgba(75, 214, 200, 0.32);
      background: rgba(18, 31, 42, 0.82);
    }

    .step-node.symbol-node.target-symbol {
      border-color: rgba(75, 214, 200, 0.8);
      box-shadow:
        0 0 0 1px rgba(75, 214, 200, 0.22),
        0 16px 38px rgba(0, 0, 0, 0.3);
    }

    .node-flow {
      display: block;
      min-width: 0;
      margin-left: 7px;
      overflow: hidden;
      color: var(--muted-2);
      font-size: 8px;
      font-weight: 750;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .step-node.pending {
      opacity: 0.44;
      filter: saturate(0.65);
    }

    .step-node.done {
      border-color: rgba(126, 226, 168, 0.28);
      background: linear-gradient(145deg, rgba(31, 55, 52, 0.79), rgba(23, 31, 44, 0.84));
    }

    .step-node.active {
      z-index: 5;
      transform: translateY(-3px) scale(1.025);
      border-color: rgba(140, 151, 255, 0.78);
      background: linear-gradient(145deg, rgba(50, 60, 120, 0.93), rgba(23, 49, 58, 0.9));
      box-shadow:
        0 18px 42px rgba(0, 0, 0, 0.34),
        0 0 0 1px rgba(140, 151, 255, 0.2),
        0 0 34px rgba(105, 125, 255, 0.18);
    }

    .node-topline {
      display: flex;
      align-items: center;
      margin-bottom: 7px;
    }

    .node-seq {
      width: 22px;
      height: 22px;
      display: grid;
      place-items: center;
      border-radius: 7px;
      color: var(--muted);
      background: rgba(255, 255, 255, 0.06);
      font-size: 9px;
      font-weight: 850;
    }

    .step-node.active .node-seq {
      color: #fff;
      background: linear-gradient(145deg, var(--accent), var(--accent-2));
    }

    .node-title {
      overflow: hidden;
      color: #e9edfa;
      font-size: 11px;
      font-weight: 760;
      line-height: 1.35;
      text-overflow: ellipsis;
    }

    .node-code {
      overflow: hidden;
      margin-top: 5px;
      color: #a7b4d1;
      font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
      font-size: 8px;
      line-height: 1.35;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .symbol-search-section {
      margin: 10px 0 16px;
      padding: 10px;
      border: 1px solid rgba(151, 166, 207, 0.14);
      background: rgba(255, 255, 255, 0.035);
    }

    .symbol-search-title {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 8px;
      color: #dce4f7;
      font-size: 10px;
      font-weight: 800;
      text-transform: uppercase;
    }

    .symbol-search-item {
      width: 100%;
      display: grid;
      gap: 3px;
      margin-top: 6px;
      padding: 9px;
      border: 1px solid rgba(151, 166, 207, 0.12);
      color: inherit;
      background: rgba(10, 14, 24, 0.5);
      text-align: left;
      cursor: pointer;
    }

    .symbol-search-item:hover {
      border-color: rgba(75, 214, 200, 0.4);
      background: rgba(75, 214, 200, 0.08);
    }

    .symbol-search-item strong {
      overflow: hidden;
      color: #edf4ff;
      font-size: 10px;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .symbol-search-item span,
    .symbol-search-item code {
      overflow: hidden;
      color: var(--muted-2);
      font-size: 8px;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .side-stack {
      display: grid;
      gap: 18px;
      position: sticky;
      top: 88px;
    }

    .detail-panel,
    .log-panel {
      overflow: hidden;
      border-radius: var(--radius-lg);
    }

    .detail-body { padding: 16px 18px 18px; }

    .detail-section + .detail-section { margin-top: 16px; }

    .detail-kicker {
      margin-bottom: 5px;
      color: var(--muted-2);
      font-size: 9px;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .detail-value {
      color: #dce3f5;
      font-size: 11px;
      line-height: 1.7;
      word-break: break-word;
    }

    .detail-chip-list,
    .detail-edge-list {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .detail-chip {
      max-width: 100%;
      padding: 5px 8px;
      border: 1px solid rgba(151, 166, 207, 0.14);
      border-radius: 999px;
      color: #cdd6ef;
      background: rgba(255, 255, 255, 0.045);
      font-size: 9px;
      line-height: 1.4;
      overflow-wrap: anywhere;
    }

    .detail-edge-list {
      display: grid;
      grid-template-columns: 1fr;
    }

    .detail-edge-card {
      display: grid;
      gap: 5px;
      padding: 8px;
      border: 1px solid rgba(127, 140, 255, 0.18);
      border-radius: 8px;
      background: rgba(127, 140, 255, 0.06);
    }

    .detail-edge-card strong,
    .detail-edge-card span,
    .detail-edge-card code {
      min-width: 0;
      overflow-wrap: anywhere;
    }

    .detail-edge-card strong {
      color: #eef2ff;
      font-size: 10px;
      line-height: 1.4;
    }

    .detail-edge-card span {
      color: var(--muted);
      font-size: 9px;
      line-height: 1.45;
    }

    .detail-edge-card code {
      color: #9fb3da;
      font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
      font-size: 8px;
      line-height: 1.45;
    }

    .source-path {
      display: block;
      padding: 9px 10px;
      border: 1px solid rgba(151, 166, 207, 0.13);
      border-radius: 10px;
      color: #b8c4e0;
      background: rgba(0, 0, 0, 0.16);
      font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
      font-size: 9px;
      line-height: 1.5;
      word-break: break-all;
    }

    .log-body {
      max-height: 278px;
      overflow: auto;
      padding: 11px 13px 14px;
      background: rgba(1, 4, 9, 0.34);
      font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
      scrollbar-width: thin;
      scrollbar-color: rgba(160, 172, 205, 0.28) transparent;
    }

    .log-entry:last-child { border-bottom: 0; }
    .log-time { color: #606b82; }
    .log-lane { color: var(--accent-2); }
    .log-entry.current { color: #e5eaff; background: rgba(127, 140, 255, 0.07); }

    .log-entry {
      border: 0;
      text-align: left;
      width: 100%;
      appearance: none;
      cursor: pointer;
      display: grid;
      grid-template-columns: 48px 54px minmax(0, 1fr);
      gap: 8px;
      padding: 7px 5px;
      border-bottom: 1px solid rgba(151, 166, 207, 0.08);
      color: #a8b3cc;
      font-size: 8px;
      line-height: 1.55;
      background: transparent;
    }

    .log-entry:hover { background: rgba(255, 255, 255, 0.032); }

    .log-entry.current { color: #e5eaff; background: rgba(127, 140, 255, 0.07); }

    .empty-state {
      padding: 36px 20px;
      color: var(--muted);
      text-align: center;
      font-size: 12px;
    }

    .footer-note {
      display: flex;
      justify-content: space-between;
      gap: 14px;
      margin-top: 16px;
      padding: 0 4px 10px;
      color: var(--muted-2);
      font-size: 9px;
      line-height: 1.6;
    }

    .mobile-menu-button { display: none; }

    @media (max-width: 1180px) {
      :root { --sidebar-width: 310px; }
      .content-grid { grid-template-columns: minmax(0, 1fr); }
      .flow-relation-layout { grid-template-columns: 1fr; }
      .flow-current-card { order: -1; }
      .side-stack {
        position: static;
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 900px) {
      .app-shell { grid-template-columns: 1fr; }
      .sidebar {
        position: fixed;
        inset: 0 auto 0 0;
        width: min(86vw, 330px);
        transform: translateX(-105%);
        transition: transform 220ms ease;
        box-shadow: 20px 0 60px rgba(0,0,0,.5);
      }
      .sidebar.open { transform: translateX(0); }
      .mobile-menu-button { display: inline-flex; }
      .main { padding: 14px; }
      .topbar { top: 8px; }
      .hero { grid-template-columns: 1fr; }
      .hero-card { min-height: auto; }
      .side-stack { grid-template-columns: 1fr; }
    }

    @media (max-width: 620px) {
      .topbar { align-items: flex-start; }
      .breadcrumb { padding-top: 7px; }
      .controls { gap: 6px; }
      .control-button span.label { display: none; }
      .toggle-control span { display: none; }
      .hero-card, .status-card { padding: 19px; }
      .flow-relation-map { padding: 12px; }
      .hero h2 { font-size: 28px; }
      .hero-summary { font-size: 12px; }
      .legend { display: none; }
      .footer-note { flex-direction: column; }
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        scroll-behavior: auto !important;
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
    }
  </style>
</head>
<body>
  <div class="app-shell">
    <aside class="sidebar" id="sidebar" aria-label="йҚ®кҫ©м«°?лҚүл’Ә ?лЁ®м«« ?мўҸк№®">
      <div class="brand">
        <div class="brand-row">
          <div class="brand-mark" aria-hidden="true">MP</div>
          <div>
            <h1>MindPhase Lifecycle</h1>
            <p>?лӮ…в”° ?г…Ҫл»ҫ??йҚ®кҫ©м«°?лҚүл’Ә жҝЎм’–мӯ… ?мўҠл•Іп§Һл¶ҝм” ??/p>
          </div>
        </div>
      </div>
      <div class="search-wrap">
        <input id="flowSearch" type="search" placeholder="?лЁ®м««, п§ҸлӮ…мЎҠ, ?лҡҜм”Ә еҜғВҖ?? autocomplete="off" />
        <div class="relation-toolbar">
          <div>
            <strong>Flow ?кіҢк»җ</strong>
            <span>?кҫ©мҳұ flow??п§һкіём ’ ?кіҢк»җ ?м’–л–Ҷ</span>
          </div>
          <button class="relation-toggle active" id="relationToggle" type="button" aria-pressed="true">ON</button>
        </div>
        <div class="relation-legend" aria-label="Flow ж„ҝВҖжҖЁ??мўҸмӮҺ">
          <span><i class="relation-swatch call"></i>?лӘ„н…§</span>
          <span><i class="relation-swatch event"></i>?лҢҖк№Ҫ??/span>
          <span><i class="relation-swatch sync"></i>?мҲҶлҰ°??/span>
          <span><i class="relation-swatch cleanup"></i>?ләЈв”Ғ</span>
        </div>
      </div>
      <nav class="flow-list" id="flowList"></nav>
    </aside>

    <main class="main">
      <header class="topbar">
        <div class="breadcrumb">
          <button class="control-button mobile-menu-button" id="menuButton" aria-label="?лЁ®м«« п§Ҹв‘ёмӨү ?лӢҝлҰ°">??/button>
          <span id="groupCrumb">App Lifecycle</span>
          <span>??/span>
          <strong id="flowCrumb">Rust / Tauri йҒәВҖ?лӘ„л’Ә?лӘғмҳӘ</strong>
        </div>
        <div class="controls" aria-label="?мўҠл•Іп§Һл¶ҝм” ??иҖҢв‘Ұл“ғжҝЎ?>
          <button class="control-button" id="prevButton" title="?лҢҒмҹҫ ?в‘ЈнҖҺ (??">??<span class="label">?лҢҒмҹҫ</span></button>
          <button class="control-button primary" id="playButton" title="?СҠк№®/?мҮұл–Ҷ?ләӨ? (Space)">??<span class="label">?СҠк№®</span></button>
          <button class="control-button" id="nextButton" title="?г…јм“¬ ?в‘ЈнҖҺ (??"><span class="label">?г…јм“¬</span> ??/button>
          <select class="select-control" id="speedSelect" title="?СҠк№® ?лқҫлЈ„">
            <option value="2200">0.6нҡһ</option>
            <option value="1500" selected>1нҡһ</option>
            <option value="900">1.6нҡһ</option>
            <option value="520">2.6нҡһ</option>
          </select>
          <label class="toggle-control" title="п§ҚлҚү?п§Қ??в‘ЈнҖҺ ?лҢ„мҚ‘ ?г…јм“¬ ?лЁ®м««?мҮ°мӨҲ ?лҢҖлЈһ">
            <input id="loopToggle" type="checkbox" checked />
            <span>?кҫ©к»ң ?м’—мҶҡ</span>
          </label>
        </div>
      </header>

      <section class="hero">
        <article class="hero-card">
          <div class="eyebrow" id="flowGroup">App Lifecycle</div>
          <h2 id="flowTitle">Rust / Tauri йҒәВҖ?лӘ„л’Ә?лӘғмҳӘ</h2>
          <p class="hero-summary" id="flowSummary"></p>
          <div class="hero-meta" id="heroMeta"></div>
        </article>
        <article class="status-card" aria-live="polite">
          <div>
            <div class="status-label">?кҫ©мҳұ ?г…Ҫл»ҫ ?в‘ЈнҖҺ</div>
            <div class="current-step-title" id="currentStepTitle"></div>
            <div class="current-step-desc" id="currentStepDesc"></div>
          </div>
          <div class="progress-shell">
            <div class="progress-meta">
              <span id="progressLabel">1 / 1</span>
              <span id="progressPercent">100%</span>
            </div>
            <div class="progress-track"><div class="progress-bar" id="progressBar"></div></div>
          </div>
        </article>
      </section>

      <section class="content-grid">
        <article class="flow-board">
          <div class="board-head">
            <div>
              <h3>?лӘ„н…§ ж„ҝВҖжҖЁ??мўҠл•Іп§Һл¶ҝм” ??/h3>
              <p>еӘӣВҖжҝЎ??лҚүм”Ө?ВҖ п§ўлӮҶм—« жҖЁкҫ©л§Ғ, ?лӘғмӨҲ ?м’–кҪҢ???г…Ҫл»ҫ ?м’–кҪҢз‘ң??м„Һ??в‘ёл•І??</p>
            </div>
            <div class="legend" aria-label="?кі№к№ӯ иё°л¶ҫ?">
              <span class="legend-item"><i class="legend-dot done"></i>?кҫЁмҰә</span>
              <span class="legend-item"><i class="legend-dot active"></i>?г…Ҫл»ҫ д»Ҙ?/span>
              <span class="legend-item"><i class="legend-dot pending"></i>?ВҖж№І?/span>
            </div>
          </div>
          <div class="flow-relation-map" id="flowRelationMap" aria-live="polite"></div>
          <div class="board-scroll" id="boardScroll">
            <div class="lane-heads" id="laneHeads"></div>
            <div class="diagram-wrap" id="diagramWrap">
              <svg class="edge-layer" id="edgeLayer" aria-hidden="true">
                <defs>
                  <linearGradient id="activeGradient" x1="0" y1="0" x2="1" y2="0">
                    <stop offset="0%" stop-color="#7f8cff" />
                    <stop offset="100%" stop-color="#4bd6c8" />
                  </linearGradient>
                </defs>
              </svg>
              <div class="diagram-grid" id="diagramGrid"></div>
            </div>
          </div>
        </article>

        <aside class="side-stack">
          <article class="detail-panel">
            <div class="panel-head">
              <div>
                <h3>Active Step ?кіёкҪӯ</h3>
                <p>?мўҸк№®??step-node????лё·, ?лӘ„н…§, Function I/O</p>
              </div>
            </div>
            <div class="detail-body">
              <div class="detail-section">
                <div class="detail-kicker">п§ўлӮҶм—«</div>
                <div class="detail-value" id="detailRole"></div>
              </div>
              <div class="detail-section">
                <div class="detail-kicker">?лӘ„н…§ / ?лҢҖк№Ҫ??/div>
                <div class="detail-value" id="detailCall"></div>
              </div>
              <div class="detail-section">
                <div class="detail-kicker">?лҡҜл’Ә еҜғмҺҲмӨҲ</div>
                <code class="source-path" id="detailSource"></code>
              </div>
              <div class="detail-section">
                <div class="detail-kicker">Function Inputs</div>
                <div class="detail-chip-list" id="detailInputs"></div>
              </div>
              <div class="detail-section">
                <div class="detail-kicker">Function Outputs</div>
                <div class="detail-chip-list" id="detailOutputs"></div>
              </div>
              <div class="detail-section">
                <div class="detail-kicker">Function Edges</div>
                <div class="detail-edge-list" id="detailEdges"></div>
              </div>
            </div>
          </article>

          <article class="log-panel">
            <div class="panel-head">
              <div>
