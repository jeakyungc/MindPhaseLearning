        'src/lib/page/controllers/app-theme-controller.svelte.ts -> src/lib/page/page-route-lifecycle.svelte.ts'),
    ];

    enrichFlowSteps();
    const FUNCTION_EDGES = [
      ...buildSequentialFunctionEdges(),
      ...CROSS_FUNCTION_EDGES.map(normalizeFunctionEdge),
    ];

    function F(id, kind, fromFlow, fromStep, toFlow, toStep, fromFunction, toFunction, payload, effect, source) {
      return { id, kind, fromFlow, fromStep, toFlow, toStep, fromFunction, toFunction, payload, effect, source };
    }

    function normalizeList(value) {
      if (Array.isArray(value)) return value.filter(Boolean);
      if (value == null || value === '') return [];
      return [String(value)];
    }

    function stepIdFor(flowId, index) {
      return `${flowId}:${String(index + 1).padStart(2, '0')}`;
    }

    function enrichFlowSteps() {
      FLOWS.forEach(flow => {
        flow.steps.forEach((step, index) => {
          step.id = step.id || stepIdFor(flow.id, index);
          step.flowId = flow.id;
          step.index = index;
          step.inputs = normalizeList(step.inputs);
          step.outputs = normalizeList(step.outputs);
          if (!step.inputs.length) {
            step.inputs = [index === 0 ? `Trigger: ${flow.trigger}` : flow.steps[index - 1].result];
          }
          if (!step.outputs.length) {
            step.outputs = [step.result];
          }
        });
      });
    }

    function resolveStepId(flowId, selector) {
      const flow = flowById(flowId);
      if (!flow) throw new Error(`Unknown flow: ${flowId}`);
      if (Number.isInteger(selector)) {
        const step = flow.steps[selector - 1];
        if (!step) throw new Error(`Unknown step index ${selector} in ${flowId}`);
        return step.id;
      }
      const selectorText = String(selector);
      const direct = flow.steps.find(step => step.id === selectorText);
      if (direct) return direct.id;
      const query = selectorText.toLowerCase();
      const matched = flow.steps.find(step => [
        step.title,
        step.code,
        step.call,
        step.source,
      ].some(value => String(value).toLowerCase().includes(query)));
      if (!matched) throw new Error(`Unknown step selector "${selectorText}" in ${flowId}`);
      return matched.id;
    }

    function normalizeFunctionEdge(edge) {
      return {
        ...edge,
        fromStep: resolveStepId(edge.fromFlow, edge.fromStep),
        toStep: resolveStepId(edge.toFlow, edge.toStep),
      };
    }

    function buildSequentialFunctionEdges() {
      return FLOWS.flatMap(flow => flow.steps.slice(0, -1).map((step, index) => {
        const next = flow.steps[index + 1];
        return F(
          `${flow.id}:${String(index + 1).padStart(2, '0')}-to-${String(index + 2).padStart(2, '0')}`,
          'internal',
          flow.id,
          step.id,
          flow.id,
          next.id,
          step.call,
          next.call,
          step.outputs.join('; '),
          next.inputs.join('; '),
          `${step.source} -> ${next.source}`,
        );
      }));
    }

    const state = {
      flowIndex: 0,
      stepIndex: 0,
      playing: false,
      timer: null,
      speed: 1500,
      loopAll: true,
      filter: '',
      showFlowRelations: true,
      selectedSymbolId: '',
    };

    let CODEBASE_GRAPH = null;

    const els = Object.fromEntries([
      'flowList','flowSearch','groupCrumb','flowCrumb','flowGroup','flowTitle','flowSummary','heroMeta',
      'currentStepTitle','currentStepDesc','progressLabel','progressPercent','progressBar','laneHeads',
      'flowRelationMap','diagramWrap','diagramGrid','edgeLayer','detailRole','detailCall','detailSource',
      'detailInputs','detailOutputs','detailEdges',
      'logBody','boardScroll','prevButton','playButton','nextButton','speedSelect',
      'loopToggle','resetButton','sidebar','menuButton','relationToggle'
    ].map(id => [id, document.getElementById(id)]));

    function currentFlow() { return FLOWS[state.flowIndex]; }
    function currentStep() { return currentFlow().steps[state.stepIndex]; }

    function renderLaneHeads() {
      els.laneHeads.innerHTML = LANES.map(lane => `
        <div class="lane-head">
          <strong>${escapeHtml(lane.label)}</strong>
          <span>${escapeHtml(lane.sub)}</span>
        </div>
      `).join('');
    }

    function flowById(id) {
      return FLOWS.find(flow => flow.id === id) ?? null;
    }

    function flowIndexById(id) {
      return FLOWS.findIndex(flow => flow.id === id);
    }

    function relationsForFlow(flowId) {
      return GROUP_RELATIONS.filter(relation => relation.fromFlow === flowId || relation.toFlow === flowId);
    }

    function functionEdgesForFlow(flowId) {
      return FUNCTION_EDGES.filter(edge => edge.fromFlow === flowId || edge.toFlow === flowId);
    }

    function crossFunctionEdgesForFlow(flowId) {
      return functionEdgesForFlow(flowId).filter(edge => edge.fromFlow !== edge.toFlow);
    }

    function functionEdgesForStep(flowId, stepId) {
      const incoming = FUNCTION_EDGES.filter(edge => edge.toFlow === flowId && edge.toStep === stepId);
      const outgoing = FUNCTION_EDGES.filter(edge => edge.fromFlow === flowId && edge.fromStep === stepId);
      return { incoming, outgoing };
    }

    function stepById(flowId, stepId) {
      return flowById(flowId)?.steps.find(step => step.id === stepId) ?? null;
    }

    function stepLabel(flowId, stepId) {
      const flow = flowById(flowId);
      const step = stepById(flowId, stepId);
      if (!flow || !step) return stepId;
      return `${flow.title} / ${String(step.index + 1).padStart(2, '0')} ${step.title}`;
    }

    function boardNodeKey(flowId, stepId) {
      return `${flowId}::${stepId}`;
    }

    function buildBoardProjection(flow) {
      const crossEdges = crossFunctionEdgesForFlow(flow.id);
      const rows = [];
      const nodes = [];
      const seen = new Set();

      function addNode(flowId, stepId, role, edge = null) {
        const step = stepById(flowId, stepId);
        const nodeFlow = flowById(flowId);
        if (!step || !nodeFlow) return;
        const key = boardNodeKey(flowId, stepId);
        if (seen.has(`${role}:${key}`)) return;
        seen.add(`${role}:${key}`);
        rows.push({ flowId, stepId, role, edge });
        const laneIndex = Math.max(0, LANES.findIndex(lane => lane.id === step.lane));
        nodes.push({
          key,
          role,
          flowId,
          stepId,
          flow: nodeFlow,
          step,
          laneIndex,
          row: rows.length,
        });
      }

      crossEdges
        .filter(edge => edge.toFlow === flow.id)
        .forEach(edge => addNode(edge.fromFlow, edge.fromStep, 'incoming', edge));

      flow.steps.forEach(step => addNode(flow.id, step.id, 'current'));

      crossEdges
        .filter(edge => edge.fromFlow === flow.id)
        .forEach(edge => addNode(edge.toFlow, edge.toStep, 'outgoing', edge));

      return { nodes, edges: crossEdges, rowCount: Math.max(rows.length, flow.steps.length) };
    }

    function renderBoardNode(node) {
      const classes = [
        'step-node',
        `${node.role}-node`,
        node.role !== 'current' ? 'context-node' : '',
      ].filter(Boolean).join(' ');
      const seq = node.role === 'current'
        ? String(node.step.index + 1)
        : node.role === 'incoming' ? 'IN' : 'OUT';
      return `
        <article class="${classes}"
                 data-flow-id="${escapeHtml(node.flowId)}"
                 data-step-id="${escapeHtml(node.stepId)}"
                 data-node-key="${escapeHtml(node.key)}"
                 ${node.flowId === currentFlow().id ? `data-step-index="${node.step.index}"` : ''}
                 style="grid-column:${node.laneIndex + 1};grid-row:${node.row}">
          <div class="node-topline">
            <span class="node-seq">${escapeHtml(seq)}</span>
            <span class="node-flow">${escapeHtml(node.flow.group)} / ${escapeHtml(node.flow.title)}</span>
          </div>
          <div class="node-title">${escapeHtml(node.step.title)}</div>
          <div class="node-code">${escapeHtml(node.step.code)}</div>
        </article>
      `;
    }

    function graphSymbolsForStep(step) {
      if (!CODEBASE_GRAPH?.symbols?.length) return [];
      const callName = String(step.call || step.code || '').match(/[A-Za-z_$][\w$]*/)?.[0];
      return CODEBASE_GRAPH.symbols.filter(symbol => {
        if (symbol.repoPath !== step.source) return false;
        if (!callName) return true;
        return symbol.name === callName || String(symbol.signature || '').includes(callName);
      }).slice(0, 3);
    }

    function sourceReferenceMarkup(step) {
      const symbols = graphSymbolsForStep(step);
      if (!symbols.length) return escapeHtml(step.source);
      return symbols.map(symbol => {
        const range = symbol.range;
        const label = `${range.repoPath}:${range.startLine}${range.endLine !== range.startLine ? `-${range.endLine}` : ''}`;
        return `<a href="${escapeHtml(range.githubUrl)}" target="_blank" rel="noreferrer" title="${escapeHtml(range.localPath || '')}" data-local-path="${escapeHtml(range.localPath || '')}">${escapeHtml(label)}</a>`;
      }).join('<br>');
    }

    function codebaseSymbolById(symbolId) {
      return CODEBASE_GRAPH?.symbols?.find(symbol => symbol.id === symbolId) ?? null;
    }

    function codebaseFileById(fileId) {
      return CODEBASE_GRAPH?.files?.find(file => file.id === fileId) ?? null;
    }

    function symbolLocationLabel(symbol) {
      const range = symbol?.range;
      if (!range) return '';
      return `${range.repoPath}:${range.startLine}${range.endLine !== range.startLine ? `-${range.endLine}` : ''}`;
    }

    function symbolSourceLink(symbol) {
      if (!symbol?.range) return '';
      const label = symbolLocationLabel(symbol);
      return `<a href="${escapeHtml(symbol.range.githubUrl)}" target="_blank" rel="noreferrer" title="${escapeHtml(symbol.range.localPath || '')}" data-local-path="${escapeHtml(symbol.range.localPath || '')}">${escapeHtml(label)}</a>`;
    }

    function codebaseEdgesForSymbol(symbolId) {
      if (!CODEBASE_GRAPH?.edges?.length) return { incoming: [], outgoing: [] };
      return {
        incoming: CODEBASE_GRAPH.edges.filter(edge => edge.to === symbolId && edge.from !== symbolId).slice(0, 24),
        outgoing: CODEBASE_GRAPH.edges.filter(edge => edge.from === symbolId && edge.to && edge.to !== symbolId).slice(0, 24),
      };
    }

    function codebaseSymbolSearchResults(query) {
      if (!CODEBASE_GRAPH?.symbols?.length || query.length < 2) return [];
      const normalized = query.toLowerCase();
      return CODEBASE_GRAPH.symbols
        .filter(symbol => [
          symbol.name,
          symbol.kind,
          symbol.signature,
          symbol.repoPath,
          symbol.range?.repoPath,
        ].some(value => String(value || '').toLowerCase().includes(normalized)))
        .sort((a, b) => symbolSearchScore(b, normalized) - symbolSearchScore(a, normalized))
        .slice(0, 12);
    }

    function symbolSearchScore(symbol, query) {
      const name = String(symbol.name || '').toLowerCase();
      const signature = String(symbol.signature || '').toLowerCase();
      const path = String(symbol.range?.repoPath || symbol.repoPath || '').toLowerCase();
      let score = 0;
      if (name === query) score += 1000;
      if (name.includes(query)) score += 300;
      if (signature.includes(query)) score += 80;
      if (path.includes(query)) score += 30;
      if (symbol.kind === 'tauri-command') score += 220;
      if (symbol.kind === 'event') score += 180;
      if (symbol.exported) score += 20;
      return score;
    }

    function renderSymbolSearchSection(query) {
      const results = codebaseSymbolSearchResults(query);
      if (!results.length) return '';
      return `
        <section class="symbol-search-section">
          <div class="symbol-search-title">
            <span>Code Symbols</span>
            <span>${results.length}</span>
          </div>
          ${results.map(symbol => `
            <button class="symbol-search-item" type="button" data-symbol-id="${escapeHtml(symbol.id)}">
              <strong>${escapeHtml(symbol.name)}</strong>
              <span>${escapeHtml(symbol.kind)} / ${escapeHtml(symbol.language)}</span>
              <code>${escapeHtml(symbolLocationLabel(symbol))}</code>
            </button>
          `).join('')}
        </section>
      `;
    }

    function buildSymbolBoardProjection(symbolId) {
      const target = codebaseSymbolById(symbolId);
      if (!target) return null;
      const { incoming, outgoing } = codebaseEdgesForSymbol(symbolId);
      const nodes = [];
      const seen = new Set();
      const projectedEdges = [];

      function addSymbolNode(symbol, role, row, laneIndex) {
        if (!symbol || seen.has(symbol.id)) return;
        seen.add(symbol.id);
        nodes.push({ symbol, role, row, laneIndex });
      }

      function placeholderSymbol(edge, side) {
        return {
          id: `placeholder:${edge.id}:${side}`,
          kind: edge.kind || 'edge',
          name: edge.unresolvedName || edge.label || 'unresolved',
          signature: edge.label || edge.unresolvedName || '',
          language: 'unresolved',
          repoPath: edge.range?.repoPath || '',
          range: edge.range,
          exported: false,
        };
      }

      addSymbolNode(target, 'target', Math.max(1, Math.ceil(Math.max(incoming.length, outgoing.length, 1) / 2)), 2);
      incoming.forEach((edge, index) => {
        const peer = codebaseSymbolById(edge.from) || placeholderSymbol(edge, 'from');
        addSymbolNode(peer, 'incoming', index + 1, 0);
        projectedEdges.push({ ...edge, fromKey: peer.id, toKey: target.id, peerId: peer.id });
      });
      outgoing.forEach((edge, index) => {
        const peer = codebaseSymbolById(edge.to) || placeholderSymbol(edge, 'to');
        addSymbolNode(peer, 'outgoing', index + 1, 4);
        projectedEdges.push({ ...edge, fromKey: target.id, toKey: peer.id, peerId: peer.id });
      });

      return {
        target,
        nodes,
        edges: projectedEdges,
        rowCount: Math.max(incoming.length, outgoing.length, 1),
      };
    }

    function renderSymbolNode(node) {
      const symbol = node.symbol;
      const seq = node.role === 'target' ? 'SEL' : node.role === 'incoming' ? 'IN' : 'OUT';
      return `
        <article class="step-node symbol-node ${node.role === 'target' ? 'target-symbol' : 'context-node'}"
                 data-symbol-id="${escapeHtml(symbol.id)}"
                 data-node-key="${escapeHtml(symbol.id)}"
                 style="grid-column:${node.laneIndex + 1} / span 2;grid-row:${node.row}">
          <div class="node-topline">
            <span class="node-seq">${escapeHtml(seq)}</span>
            <span class="node-flow">${escapeHtml(symbol.kind)} / ${escapeHtml(symbol.language)}</span>
          </div>
          <div class="node-title">${escapeHtml(symbol.name)}</div>
          <div class="node-code">${escapeHtml(symbolLocationLabel(symbol))}</div>
        </article>
      `;
    }

    function renderSymbolBoard(symbolId) {
      const projection = buildSymbolBoardProjection(symbolId);
      if (!projection) return;
      const symbol = projection.target;
      els.flowTitle.textContent = symbol.name;
      els.flowSummary.textContent = symbol.signature || symbolLocationLabel(symbol);
      els.flowGroup.textContent = 'Code Symbol Graph';
      els.groupCrumb.textContent = 'Code Symbol Graph';
      els.flowCrumb.textContent = symbol.name;
      els.heroMeta.innerHTML = [
        `<span class="meta-chip">${escapeHtml(symbol.kind)}</span>`,
        `<span class="meta-chip">${escapeHtml(symbol.language)}</span>`,
        `<span class="meta-chip">${escapeHtml(symbolLocationLabel(symbol))}</span>`,
      ].join('');
      els.currentStepTitle.textContent = symbol.name;
      els.currentStepDesc.textContent = symbol.signature || '';
      els.progressLabel.textContent = `${projection.edges.length} edges`;
      els.progressPercent.textContent = CODEBASE_GRAPH?.stats ? `${CODEBASE_GRAPH.stats.symbols} symbols` : '';
      els.progressBar.style.width = '100%';
      els.detailRole.textContent = `${symbol.kind} / ${symbol.language}`;
      els.detailCall.textContent = symbol.signature || symbol.name;
      els.detailSource.innerHTML = symbolSourceLink(symbol);
      els.detailInputs.innerHTML = renderDetailChipList(codebaseEdgesForSymbol(symbol.id).incoming.map(edge => edge.label || edge.kind).slice(0, 8));
      els.detailOutputs.innerHTML = renderDetailChipList(codebaseEdgesForSymbol(symbol.id).outgoing.map(edge => edge.label || edge.kind).slice(0, 8));
      els.detailEdges.innerHTML = projection.edges.slice(0, 12).map(edge => {
        const peer = codebaseSymbolById(edge.peerId) || projection.nodes.find(node => node.symbol.id === edge.peerId)?.symbol;
        return `<button class="detail-edge-card" type="button" data-symbol-id="${escapeHtml(peer?.id || '')}">
          <strong>${escapeHtml(edge.kind.toUpperCase())} / ${escapeHtml(edge.confidence || '')}</strong>
          <span>${escapeHtml(edge.label || edge.unresolvedName || '')}</span>
          <code>${escapeHtml(peer ? symbolLocationLabel(peer) : 'unresolved')}</code>
        </button>`;
      }).join('') || '<span class="detail-chip">No symbol edges.</span>';
      els.detailEdges.querySelectorAll('[data-symbol-id]').forEach(button => {
        button.addEventListener('click', () => selectSymbolById(button.dataset.symbolId));
      });
      els.logBody.innerHTML = projection.edges.slice(0, 20).map((edge, index) => `
        <div class="log-entry ${index === 0 ? 'current' : ''}">
          <span class="log-time">${escapeHtml(edge.kind)}</span>
          <span class="log-lane">${escapeHtml(edge.confidence || '')}</span>
          <span>${escapeHtml(edge.label || edge.unresolvedName || '')}</span>
        </div>
      `).join('');
      els.flowRelationMap.hidden = false;
      els.flowRelationMap.innerHTML = `
        <div class="flow-relation-layout">
          <section class="flow-relation-column"><div class="flow-relation-column-head"><strong>Incoming symbols</strong><span class="flow-relation-badge">${codebaseEdgesForSymbol(symbol.id).incoming.length}</span></div></section>
          <article class="flow-current-card"><div class="flow-current-label">Selected symbol</div><div class="flow-current-title">${escapeHtml(symbol.name)}</div><div class="flow-current-group">${symbolSourceLink(symbol)}</div></article>
          <section class="flow-relation-column"><div class="flow-relation-column-head"><strong>Outgoing symbols</strong><span class="flow-relation-badge">${codebaseEdgesForSymbol(symbol.id).outgoing.length}</span></div></section>
        </div>
      `;
      els.diagramGrid.style.gridTemplateRows = `repeat(${projection.rowCount}, minmax(94px, auto))`;
      els.diagramGrid.innerHTML = projection.nodes.map(renderSymbolNode).join('');
      els.diagramGrid.querySelectorAll('[data-symbol-id]').forEach(node => {
        node.addEventListener('click', () => selectSymbolById(node.dataset.symbolId));
      });
      requestAnimationFrame(drawEdges);
      renderSidebar();
    }

    function relationKind(relation) {
      return RELATION_KINDS[relation.kind] ?? RELATION_KINDS.call;
    }

    function renderFlowRelationCard(relation, direction) {
      const kind = relationKind(relation);
      const targetFlowId = direction === 'incoming' ? relation.fromFlow : relation.toFlow;
      const targetFlowTitle = flowById(targetFlowId)?.title ?? targetFlowId;
      const fromFlowTitle = flowById(relation.fromFlow)?.title ?? relation.fromFlow;
      const toFlowTitle = flowById(relation.toFlow)?.title ?? relation.toFlow;
      const roleText = direction === 'incoming' ? '??flowз‘ң??Сүл’— ?кіҢк»җ' : '??flowеӘӣВҖ ?м„ҚлҰ°???кіҢк»җ';
      return `
        <button class="flow-link-card"
                type="button"
                data-target-flow-id="${escapeHtml(targetFlowId)}"
                style="--relation-color:${kind.color}"
                title="${escapeHtml(relation.description)}">
          <span class="flow-link-role">${roleText}</span>
          <span class="flow-link-title">${escapeHtml(targetFlowTitle)}</span>
          <span class="flow-link-route">${escapeHtml(`${fromFlowTitle} ??${toFlowTitle}`)}</span>
          <span class="flow-link-meta">
            <span>${escapeHtml(`${relation.from} ??${relation.to}`)}</span>
            <span class="flow-link-kind">${kind.label}</span>
          </span>
          <code class="flow-link-via">via ${escapeHtml(relation.via)}</code>
          <span class="flow-link-copy">${escapeHtml(relation.description)}</span>
        </button>
      `;
    }

    function renderFunctionEdgeCard(edge, direction) {
      const targetFlowId = direction === 'incoming' ? edge.fromFlow : edge.toFlow;
      const targetStepId = direction === 'incoming' ? edge.fromStep : edge.toStep;
      const sourceLabel = stepLabel(edge.fromFlow, edge.fromStep);
      const targetLabel = stepLabel(edge.toFlow, edge.toStep);
      const fromStep = stepById(edge.fromFlow, edge.fromStep);
      const toStep = stepById(edge.toFlow, edge.toStep);
      return `
        <button class="function-edge-card"
                type="button"
                data-target-flow-id="${escapeHtml(targetFlowId)}"
                data-target-step-id="${escapeHtml(targetStepId)}">
          <span class="function-edge-route">${escapeHtml(edge.fromFunction)} -> ${escapeHtml(edge.toFunction)}</span>
          <span class="function-edge-meta">${escapeHtml(edge.payload)} / ${escapeHtml(edge.effect)}</span>
          <span class="function-edge-source">${escapeHtml(sourceLabel)} -> ${escapeHtml(targetLabel)}</span>
          <span class="function-edge-source">${fromStep ? sourceReferenceMarkup(fromStep) : escapeHtml(edge.source)} -> ${toStep ? sourceReferenceMarkup(toStep) : ''}</span>
        </button>
      `;
    }

    function renderFunctionEdgeSection(edges, direction) {
      return `
        <div class="function-edge-section">
          <div class="function-edge-title">
            <span>Function ${direction}</span>
            <span class="flow-relation-badge">${edges.length}</span>
          </div>
          <div class="function-edge-list">
            ${edges.length
              ? edges.map(edge => renderFunctionEdgeCard(edge, direction)).join('')
              : '<div class="flow-link-empty">No cross-flow function edges.</div>'}
          </div>
        </div>
      `;
    }

    function renderFlowRelationColumn(title, emptyText, relations, direction, functionEdges) {
      return `
        <section class="flow-relation-column">
          <div class="flow-relation-column-head">
            <strong>${title}</strong>
            <span class="flow-relation-badge">${relations.length}</span>
          </div>
          <div class="flow-link-stack">
            ${relations.length
              ? relations.map(relation => renderFlowRelationCard(relation, direction)).join('')
              : `<div class="flow-link-empty">${emptyText}</div>`}
          </div>
          ${renderFunctionEdgeSection(functionEdges, direction)}
        </section>
      `;
    }

    function renderFlowRelationMap() {
      if (!els.flowRelationMap) return;
      if (!state.showFlowRelations) {
        els.flowRelationMap.hidden = true;
        els.flowRelationMap.innerHTML = '';
        return;
      }

      const flow = currentFlow();
      const relations = relationsForFlow(flow.id);
      const incoming = relations.filter(relation => relation.toFlow === flow.id);
      const outgoing = relations.filter(relation => relation.fromFlow === flow.id);
      const functionRelations = crossFunctionEdgesForFlow(flow.id);
      const functionIncoming = functionRelations.filter(edge => edge.toFlow === flow.id);
      const functionOutgoing = functionRelations.filter(edge => edge.fromFlow === flow.id);
      els.flowRelationMap.hidden = false;
      els.flowRelationMap.innerHTML = `
        <div class="flow-relation-layout">
          ${renderFlowRelationColumn('??flowз‘ң??Сүл’— ?кіҢк»җ', '?кҫ©мҳұ flowжҝЎ??г…јлјұ?г…»л’— п§һкіём ’ ?кіҢк»җ???лҶҒл’ҝ?лҚҲл–Һ.', incoming, 'incoming', functionIncoming)}
          <article class="flow-current-card">
            <div class="flow-current-label">?кҫ©мҳұ flow</div>
            <div class="flow-current-title">${escapeHtml(flow.title)}</div>
            <div class="flow-current-group">${escapeHtml(flow.group)}</div>
            <div class="flow-current-stats">
              <span>?г…јлјұ??${incoming.length}</span>
              <span>?м„Қ? ${outgoing.length}</span>
              <span>зҸҘ?${relations.length}</span>
              <span>Fn in ${functionIncoming.length}</span>
              <span>Fn out ${functionOutgoing.length}</span>
            </div>
          </article>
          ${renderFlowRelationColumn('??flowеӘӣВҖ ?м„ҚлҰ°???кіҢк»җ', '?кҫ©мҳұ flow?лЁҜкҪҢ ?м„Қ???п§һкіём ’ ?кіҢк»җ???лҶҒл’ҝ?лҚҲл–Һ.', outgoing, 'outgoing', functionOutgoing)}
        </div>
      `;

      els.flowRelationMap.querySelectorAll('[data-target-flow-id]').forEach(button => {
        button.addEventListener('click', () => {
          selectFlowById(button.dataset.targetFlowId, button.dataset.targetStepId);
        });
      });
    }

    function renderSidebar() {
      const query = state.filter.trim().toLowerCase();
      const groups = new Map();
      FLOWS.forEach((flow, index) => {
        const relationText = relationsForFlow(flow.id).flatMap(relation => [
          relation.from, relation.to, relation.via, relation.description, relationKind(relation).label,
        ]);
        const functionEdgeText = functionEdgesForFlow(flow.id).flatMap(edge => [
          edge.fromFunction, edge.toFunction, edge.payload, edge.effect, edge.source,
        ]);
        const stepText = flow.steps.flatMap(s => [
          s.id, s.title, s.code, s.call, s.source, ...s.inputs, ...s.outputs,
        ]);
        const haystack = [flow.group, flow.title, flow.summary, flow.tags.join(' '), ...relationText, ...functionEdgeText, ...stepText].join(' ').toLowerCase();
        if (query && !haystack.includes(query)) return;
        if (!groups.has(flow.group)) groups.set(flow.group, []);
        groups.get(flow.group).push({flow,index});
      });

      const symbolSearchMarkup = renderSymbolSearchSection(query);

      if (!groups.size && !symbolSearchMarkup) {
        els.flowList.innerHTML = '<div class="empty-state">?мҮұнҠӮ?м„Һл’— ?лЁ®м««???лҶҒл’ҝ?лҚҲл–Һ.</div>';
        return;
      }

      const activeGroup = currentFlow().group;
      els.flowList.innerHTML = `
        ${symbolSearchMarkup}
        ${[...groups.entries()].map(([group, items]) => {
          const isActiveGroup = group === activeGroup;
          return `
            <section class="group-block ${isActiveGroup ? 'active-group' : ''}" data-group="${escapeHtml(group)}">
              <div class="group-title">
                <span class="group-title-main"><span>${escapeHtml(group)}</span><span class="group-count">${items.length}</span></span>
              </div>
              ${items.map(({flow,index}) => {
                const relationCount = relationsForFlow(flow.id).length;
                return `
                  <button class="flow-item ${index === state.flowIndex ? 'active' : ''}" data-flow-index="${index}">
                    <span class="flow-index">${String(index + 1).padStart(2, '0')}</span>
                    <span class="flow-name">${escapeHtml(flow.title)}</span>
                    <span class="flow-meta">
                      <span class="flow-relation-count" title="???лЁ®м««жҖЁ?п§һкіём ’ ?кіҢк»җ??Flow ж„ҝВҖжҖЁ???>${relationCount ? `??{relationCount}` : ''}</span>
                      <span class="flow-step-count">${flow.steps.length}</span>
                    </span>
                  </button>
                `;
              }).join('')}
            </section>
          `;
        }).join('')}
      `;

      els.flowList.querySelectorAll('.flow-item').forEach(button => {
        button.addEventListener('click', () => {
          selectFlow(Number(button.dataset.flowIndex));
          els.sidebar.classList.remove('open');
        });
      });
      els.flowList.querySelectorAll('[data-symbol-id]').forEach(button => {
        button.addEventListener('click', () => {
          selectSymbolById(button.dataset.symbolId);
          els.sidebar.classList.remove('open');
        });
      });
    }

    function renderFlow() {
      const flow = currentFlow();
      els.groupCrumb.textContent = flow.group;
      els.flowCrumb.textContent = flow.title;
      els.flowGroup.textContent = flow.group;
      els.flowTitle.textContent = flow.title;
      els.flowSummary.textContent = flow.summary;
      els.heroMeta.innerHTML = [
        `<span class="meta-chip">Trigger мЁҢ ${escapeHtml(flow.trigger)}</span>`,
        `<span class="meta-chip">Result мЁҢ ${escapeHtml(flow.result)}</span>`,
        `<span class="meta-chip">${flow.steps.length} steps</span>`,
        ...(relationsForFlow(flow.id).length ? [`<span class="meta-chip">Flow links мЁҢ ${relationsForFlow(flow.id).length}</span>`] : []),
        ...flow.tags.slice(0, 3).map(tag => `<span class="meta-chip">${escapeHtml(tag)}</span>`),
      ].join('');

      renderFlowRelationMap();
      const boardProjection = buildBoardProjection(flow);
      els.diagramGrid.dataset.projection = JSON.stringify({
        edges: boardProjection.edges.map(edge => edge.id),
      });
      els.diagramGrid.style.gridTemplateRows = `repeat(${boardProjection.rowCount}, minmax(94px, auto))`;
      els.edgeLayer.querySelectorAll('.edge').forEach(edge => edge.remove());
      els.diagramGrid.innerHTML = boardProjection.nodes.map(renderBoardNode).join('');

      els.diagramGrid.querySelectorAll('.step-node').forEach(node => {
        node.addEventListener('click', () => {
          if (node.dataset.flowId === flow.id && node.dataset.stepIndex) {
            setStep(Number(node.dataset.stepIndex));
          } else {
            selectFlowById(node.dataset.flowId, node.dataset.stepId);
          }
        });
      });

      requestAnimationFrame(() => {
        drawEdges();
        renderStep();
      });
    }

    function renderDetailChipList(values) {
      return normalizeList(values).map(value => `<span class="detail-chip">${escapeHtml(value)}</span>`).join('');
    }

    function renderStepDetailEdge(edge, direction) {
      const peerFlowId = direction === 'incoming' ? edge.fromFlow : edge.toFlow;
      const peerStepId = direction === 'incoming' ? edge.fromStep : edge.toStep;
      const peerLabel = stepLabel(peerFlowId, peerStepId);
      const route = direction === 'incoming'
        ? `${edge.fromFunction} -> ${edge.toFunction}`
        : `${edge.fromFunction} -> ${edge.toFunction}`;
      return `
        <button class="detail-edge-card"
                type="button"
                data-target-flow-id="${escapeHtml(peerFlowId)}"
                data-target-step-id="${escapeHtml(peerStepId)}">
          <strong>${direction.toUpperCase()} / ${escapeHtml(route)}</strong>
          <span>${escapeHtml(edge.payload)} / ${escapeHtml(edge.effect)}</span>
          <code>${escapeHtml(peerLabel)}</code>
          <span>${sourceReferenceMarkup(stepById(peerFlowId, peerStepId) || {})}</span>
        </button>
      `;
    }

    function renderStepFunctionDetails(flow, step) {
      const { incoming, outgoing } = functionEdgesForStep(flow.id, step.id);
      els.detailInputs.innerHTML = renderDetailChipList(step.inputs);
      els.detailOutputs.innerHTML = renderDetailChipList(step.outputs);
      els.detailEdges.innerHTML = [
        ...incoming.map(edge => renderStepDetailEdge(edge, 'incoming')),
        ...outgoing.map(edge => renderStepDetailEdge(edge, 'outgoing')),
      ].join('') || '<span class="detail-chip">No function edges.</span>';
      els.detailEdges.querySelectorAll('[data-target-flow-id]').forEach(button => {
        button.addEventListener('click', () => {
          selectFlowById(button.dataset.targetFlowId, button.dataset.targetStepId);
        });
      });
    }

    function renderStep() {
      const flow = currentFlow();
      const step = currentStep();
      const nodes = [...els.diagramGrid.querySelectorAll('.step-node')];
      nodes.forEach(node => {
        const index = Number(node.dataset.stepIndex);
        const isCurrentFlowNode = node.dataset.flowId === flow.id && Number.isFinite(index);
        node.classList.toggle('done', isCurrentFlowNode && index < state.stepIndex);
        node.classList.toggle('active', isCurrentFlowNode && index === state.stepIndex);
        node.classList.toggle('pending', isCurrentFlowNode && index > state.stepIndex);
      });

      let activeEdge = null;
      [...els.edgeLayer.querySelectorAll('.edge')].forEach(edge => {
        const active = edge.dataset.activeStep === step.id;
        edge.classList.toggle('done', false);
        edge.classList.toggle('active', active);
        if (active) activeEdge = edge;
      });
      activeEdge?.parentNode?.appendChild(activeEdge);

      els.currentStepTitle.textContent = step.title;
      els.currentStepDesc.textContent = step.desc;
      const progress = ((state.stepIndex + 1) / flow.steps.length) * 100;
      els.progressLabel.textContent = `${state.stepIndex + 1} / ${flow.steps.length}`;
      els.progressPercent.textContent = `${Math.round(progress)}%`;
      els.progressBar.style.width = `${progress}%`;
      els.detailRole.textContent = `${LANES.find(l => l.id === step.lane).label} жҖЁкҫ©л§Ғ?лЁҜкҪҢ ${step.desc}`;
      els.detailCall.textContent = step.call;
      els.detailSource.innerHTML = sourceReferenceMarkup(step);
      renderStepFunctionDetails(flow, step);

      els.logBody.innerHTML = flow.steps.map((item, i) => `
        <button class="log-entry ${i === state.stepIndex ? 'current' : ''}" data-step-index="${i}" type="button">
          <span class="log-time">T+${String(i * 120).padStart(4,'0')}</span>
          <span class="log-lane">${escapeHtml(item.lane.toUpperCase())}</span>
          <span>${escapeHtml(item.call)} -> ${escapeHtml(item.result)}</span>
        </button>
      `).join('');
      els.logBody.querySelectorAll('[data-step-index]').forEach(entry => {
        entry.addEventListener('click', () => setStep(Number(entry.dataset.stepIndex)));
      });
      els.logBody.scrollTop = els.logBody.scrollHeight;

      const activeLog = els.logBody.querySelector(`[data-step-index="${state.stepIndex}"]`);
      activeLog?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      const activeNode = els.diagramGrid.querySelector(`[data-step-index="${state.stepIndex}"]`);
      activeNode?.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'center' });

      updatePlayButton();
    }

    function drawEdges() {
      if (state.selectedSymbolId) {
        drawSymbolEdges();
        return;
      }
      const nodes = [...els.diagramGrid.querySelectorAll('.step-node')];
      const wrapRect = els.diagramWrap.getBoundingClientRect();
      const width = els.diagramWrap.scrollWidth;
      const height = els.diagramWrap.scrollHeight;
      els.edgeLayer.setAttribute('viewBox', `0 0 ${width} ${height}`);
      els.edgeLayer.setAttribute('width', width);
      els.edgeLayer.setAttribute('height', height);

      const defs = els.edgeLayer.querySelector('defs')?.outerHTML || '';
      const paths = [];
      const rectFor = rect => {
        const left = rect.left - wrapRect.left + els.boardScroll.scrollLeft;
        const top = rect.top - wrapRect.top + els.boardScroll.scrollTop;
        return {
          left,
          top,
          right: left + rect.width,
          bottom: top + rect.height,
          centerX: left + rect.width / 2,
          centerY: top + rect.height / 2,
        };
      };

      const nodeByKey = new Map(nodes.map(node => [node.dataset.nodeKey, node]));
      const flow = currentFlow();
      const crossEdges = crossFunctionEdgesForFlow(flow.id);

      crossEdges.forEach((edge, i) => {
        const sourceNode = nodeByKey.get(boardNodeKey(edge.fromFlow, edge.fromStep));
        const targetNode = nodeByKey.get(boardNodeKey(edge.toFlow, edge.toStep));
        if (!sourceNode || !targetNode) return;
        const a = rectFor(sourceNode.getBoundingClientRect());
        const b = rectFor(targetNode.getBoundingClientRect());
        const start = edge.fromFlow === flow.id
          ? { x: a.centerX, y: a.bottom }
          : { x: a.centerX, y: a.bottom };
        const end = edge.toFlow === flow.id
          ? { x: b.centerX, y: b.top }
          : { x: b.centerX, y: b.top };
        const sameColumn = Math.abs(start.x - end.x) < 8;
        let d;
        if (sameColumn) {
          d = `M ${start.x} ${start.y} L ${end.x} ${end.y}`;
        } else {
          const gapY = Math.max(0, end.y - start.y);
          const bendOffset = Math.min(18, Math.max(10, gapY * 0.32), gapY / 2);
          const startBendY = start.y + bendOffset;
          const endBendY = end.y - bendOffset;
          const trunkX = start.x + (end.x - start.x) * 0.5;
          d = `M ${start.x} ${start.y} L ${start.x} ${startBendY} L ${trunkX} ${startBendY} L ${trunkX} ${endBendY} L ${end.x} ${endBendY} L ${end.x} ${end.y}`;
        }
        const direction = edge.toFlow === flow.id ? 'incoming' : 'outgoing';
        const activeStep = direction === 'incoming' ? edge.toStep : edge.fromStep;
        paths.push({
          index: i,
          markup: `<path class="edge cross-edge ${direction}" data-edge-id="${escapeHtml(edge.id)}" data-active-step="${escapeHtml(activeStep)}" d="${d}" />`,
        });
      });
      paths.sort((a, b) => a.index - b.index);
      els.edgeLayer.innerHTML = defs + paths.map(path => path.markup).join('');
      renderStep();
    }

    function drawSymbolEdges() {
      const projection = buildSymbolBoardProjection(state.selectedSymbolId);
      if (!projection) return;
      const nodes = [...els.diagramGrid.querySelectorAll('.symbol-node')];
      const wrapRect = els.diagramWrap.getBoundingClientRect();
      const width = els.diagramWrap.scrollWidth;
      const height = els.diagramWrap.scrollHeight;
      els.edgeLayer.setAttribute('viewBox', `0 0 ${width} ${height}`);
      els.edgeLayer.setAttribute('width', width);
      els.edgeLayer.setAttribute('height', height);
      const defs = els.edgeLayer.querySelector('defs')?.outerHTML || '';
      const nodeByKey = new Map(nodes.map(node => [node.dataset.nodeKey, node]));
      const rectFor = rect => {
        const left = rect.left - wrapRect.left + els.boardScroll.scrollLeft;
        const top = rect.top - wrapRect.top + els.boardScroll.scrollTop;
        return {
          left,
          top,
          right: left + rect.width,
          bottom: top + rect.height,
          centerX: left + rect.width / 2,
          centerY: top + rect.height / 2,
        };
      };
      const paths = projection.edges.map((edge, index) => {
        const sourceNode = nodeByKey.get(edge.fromKey || edge.from);
        const targetNode = nodeByKey.get(edge.toKey || edge.to);
        if (!sourceNode || !targetNode) return '';
        const a = rectFor(sourceNode.getBoundingClientRect());
        const b = rectFor(targetNode.getBoundingClientRect());
        const start = { x: a.right, y: a.centerY };
        const end = { x: b.left, y: b.centerY };
        const trunkX = start.x + (end.x - start.x) * 0.5;
        const d = `M ${start.x} ${start.y} C ${trunkX} ${start.y}, ${trunkX} ${end.y}, ${end.x} ${end.y}`;
        const direction = edge.to === state.selectedSymbolId ? 'incoming' : 'outgoing';
        return `<path class="edge cross-edge ${direction}" data-edge-id="${escapeHtml(edge.id)}" data-active-step="${escapeHtml(state.selectedSymbolId)}" d="${d}" />`;
      }).filter(Boolean).join('');
      els.edgeLayer.innerHTML = defs + paths;
    }

    function selectFlow(index, keepPlaying = true) {
      const wasPlaying = state.playing;
      stopTimer();
      state.selectedSymbolId = '';
      state.flowIndex = clamp(index, 0, FLOWS.length - 1);
      state.stepIndex = 0;
      renderFlow();
      if (keepPlaying && wasPlaying) startTimer();
    }

    function selectFlowById(flowId, stepId = '') {
      const targetIndex = flowIndexById(flowId);
      if (targetIndex < 0) return;
      state.filter = '';
      els.flowSearch.value = '';
      selectFlow(targetIndex);
      if (stepId) {
        const targetStepIndex = currentFlow().steps.findIndex(step => step.id === stepId);
        if (targetStepIndex >= 0) setStep(targetStepIndex);
      }
      els.sidebar.classList.remove('open');
    }

    function selectSymbolById(symbolId) {
      if (!codebaseSymbolById(symbolId)) return;
      const wasPlaying = state.playing;
      stopTimer();
      state.selectedSymbolId = symbolId;
      renderSymbolBoard(symbolId);
      if (wasPlaying) pause();
    }

    function setStep(index) {
      state.stepIndex = clamp(index, 0, currentFlow().steps.length - 1);
      renderStep();
      if (state.playing) restartTimer();
    }

    function nextStep() {
      const flow = currentFlow();
      if (state.stepIndex < flow.steps.length - 1) {
        state.stepIndex += 1;
        renderStep();
        return;
      }
      if (state.loopAll) {
        selectFlow((state.flowIndex + 1) % FLOWS.length, false);
        if (state.playing) restartTimer();
      } else {
        pause();
      }
    }

    function prevStep() {
      if (state.stepIndex > 0) {
        state.stepIndex -= 1;
        renderStep();
        return;
      }
      if (state.loopAll) {
        const prevFlow = (state.flowIndex - 1 + FLOWS.length) % FLOWS.length;
        state.flowIndex = prevFlow;
        state.stepIndex = FLOWS[prevFlow].steps.length - 1;
        renderFlow();
      }
    }

    function play() {
      state.playing = true;
      startTimer();
      updatePlayButton();
    }

    function pause() {
      state.playing = false;
      stopTimer();
      updatePlayButton();
    }

    function togglePlay() { state.playing ? pause() : play(); }

    function startTimer() {
      stopTimer();
      state.timer = window.setInterval(nextStep, state.speed);
    }

    function restartTimer() { if (state.playing) startTimer(); }

    function stopTimer() {
      if (state.timer) window.clearInterval(state.timer);
      state.timer = null;
    }

    function updatePlayButton() {
      els.playButton.innerHTML = state.playing ? '?мӢўм”Ӯ <span class="label">?мҮұл–Ҷ?ләӨ?</span>' : '??<span class="label">?СҠк№®</span>';
      els.playButton.setAttribute('aria-label', state.playing ? '?мҮұл–Ҷ?ләӨ?' : '?СҠк№®');
    }

    function clamp(value, min, max) { return Math.min(max, Math.max(min, value)); }

    function escapeHtml(value) {
      return String(value).replace(/[&<>'"]/g, char => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[char]));
    }

    async function loadCodebaseGraph() {
      try {
        const response = await fetch('generated/mindphase-codebase-graph.json', { cache: 'no-store' });
        if (!response.ok) throw new Error(`HTTP ${response.status}`);
        CODEBASE_GRAPH = await response.json();
        if (state.selectedSymbolId) renderSymbolBoard(state.selectedSymbolId);
        else renderFlow();
        renderSidebar();
      } catch (error) {
        console.warn('[mindphase-learning] codebase graph unavailable:', error);
      }
    }

    els.prevButton.addEventListener('click', () => { prevStep(); restartTimer(); });
    els.nextButton.addEventListener('click', () => { nextStep(); restartTimer(); });
    els.playButton.addEventListener('click', togglePlay);
    els.resetButton.addEventListener('click', () => setStep(0));
    els.speedSelect.addEventListener('change', event => {
      state.speed = Number(event.target.value);
      restartTimer();
    });
    els.loopToggle.addEventListener('change', event => { state.loopAll = event.target.checked; });
    els.flowSearch.addEventListener('input', event => {
      state.filter = event.target.value;
      renderSidebar();
    });
    els.relationToggle.addEventListener('click', () => {
      state.showFlowRelations = !state.showFlowRelations;
      els.relationToggle.classList.toggle('active', state.showFlowRelations);
      els.relationToggle.textContent = state.showFlowRelations ? 'ON' : 'OFF';
      els.relationToggle.setAttribute('aria-pressed', String(state.showFlowRelations));
      renderFlowRelationMap();
    });
    els.menuButton.addEventListener('click', () => els.sidebar.classList.toggle('open'));

    document.addEventListener('click', event => {
      if (window.innerWidth > 900) return;
      if (!els.sidebar.classList.contains('open')) return;
      if (els.sidebar.contains(event.target) || els.menuButton.contains(event.target)) return;
      els.sidebar.classList.remove('open');
    });

    document.addEventListener('keydown', event => {
      const tag = document.activeElement?.tagName;
      if (tag === 'INPUT' || tag === 'SELECT' || tag === 'TEXTAREA') return;
      if (event.code === 'Space') { event.preventDefault(); togglePlay(); }
      if (event.code === 'ArrowRight') { event.preventDefault(); nextStep(); restartTimer(); }
      if (event.code === 'ArrowLeft') { event.preventDefault(); prevStep(); restartTimer(); }
      if (event.code === 'Home') { event.preventDefault(); setStep(0); }
      if (event.code === 'End') { event.preventDefault(); setStep(currentFlow().steps.length - 1); }
    });

    const resizeObserver = new ResizeObserver(() => requestAnimationFrame(drawEdges));
    resizeObserver.observe(els.diagramWrap);
    window.addEventListener('resize', () => requestAnimationFrame(drawEdges));

    renderLaneHeads();
    renderFlow();
    void loadCodebaseGraph();
  </script>
</body>
</html>
