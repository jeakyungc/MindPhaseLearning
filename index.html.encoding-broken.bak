        'document-open', 'handleWorkspaceRowClick',
        'selected graph document node',
        'openWorkspaceFile(path)',
        'graph node action opens the matching editor document',
        'src/lib/page/page-workspace-surface-runtime.ts -> src/lib/page/workspace-interaction-runtime.ts'),
      F('editor-graph-functions', 'sync',
        'editor-close', 'syncSelectionFromActiveEditor',
        'graph-interaction', 'setGraphSelectedNodeId',
