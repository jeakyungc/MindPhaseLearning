    function R(id, from, to, kind, fromFlow, toFlow, via, description) {
      return { id, from, to, kind, fromFlow, toFlow, via, description };
    }

    function S(lane, title, code, desc, call, source, result, meta = {}) {
      return {
        lane,
        title,
        code,
        desc,
        call,
        source,
        result,
        id: meta.id ?? '',
        inputs: normalizeList(meta.inputs),
        outputs: normalizeList(meta.outputs),
      };
    }

    const CROSS_FUNCTION_EDGES = [
      F('lifecycle-settings-functions', 'load',
        'page-mount', 'loadDurableState',
        'durable-preferences', 'preferencesSync.load',
        'loadDurableState()', 'DurablePreferenceSync.load()',
        'cached UI settings and backend snapshot request',
        'durable preferences are merged into controller state',
        'src/lib/page/page-lifecycle.ts -> src/lib/page/durable-preference-sync.ts'),
      F('lifecycle-workspace-functions', 'load',
        'page-mount', 'workspaceTree()',
        'workspace-tree-load', 'durableLoaders.workspaceTree',
        'workspaceTree()', 'loadWorkspaceTree()',
        'active workspace context',
        'workspace tree loading starts',
        'src/lib/page/page-lifecycle.ts -> src/lib/page/page-route-lifecycle.svelte.ts'),
      F('lifecycle-graph-functions', 'init',
        'engine-init', 'GraphRuntime.init',
        'graph-snapshot', 'GraphRuntime.reloadSnapshot',
